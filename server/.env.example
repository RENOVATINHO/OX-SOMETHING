# Dados do MySQL — copiar do painel Railway (MySQL service → Variables)
DB_HOST=containers-us-west-xxx.railway.app
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=railway

# Chave JWT — gere uma string aleatória forte (mínimo 32 caracteres)
JWT_SECRET=

# CORS — URL do seu frontend no Vercel
CORS_ORIGIN=https://seu-app.vercel.app

# Porta (Railway define automaticamente)
PORT=3001
